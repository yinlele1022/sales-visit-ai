# DeepSeek API (Primary model)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Qwen API (Fallback model)
QWEN_API_KEY=sk-your-qwen-key

# Feishu Bot Webhook (群机器人回调地址)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# Feishu User ID (可选，用于@提醒)
FEISHU_USER_ID=your-user-id

# Audit Log (可选，默认 ./audit_logs/sales_visit_ai_log.xlsx)
AUDIT_LOG_PATH=./audit_logs/sales_visit_ai_log.xlsx
